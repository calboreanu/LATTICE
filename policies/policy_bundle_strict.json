{
  "policy_id": "LATTICE_POLICY_STRICT",
  "version": "v1-strict",
  "allowed_targets": [
    "example.local"
  ],
  "permitted_tools": {
    "DEFAULT": [
      "dns_query"
    ]
  },
  "thresholds": {
    "autonomous": 90,
    "hitl": 75,
    "escalate": 60
  },
  "rules": [
    {
      "id": "R_DENY_UNKNOWN_TARGET",
      "if": {
        "target_in_allowlist": false
      },
      "then": "BLOCK"
    },
    {
      "id": "R_DENY_UNKNOWN_TOOL",
      "if": {
        "tool_allowed": false
      },
      "then": "BLOCK"
    },
    {
      "id": "R_DEFAULT",
      "then": "ALLOW"
    }
  ],
  "scope_limits": {
    "deny_by_default": true
  }
}