{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/signed_approved_bundle.schema.json",
  "title": "SignedApprovedBundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_id",
    "bundle_hash",
    "safe_state_id",
    "authorized_tools",
    "tool_hashes",
    "constraints",
    "coa",
    "decision_tree",
    "signature"
  ],
  "properties": {
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "bundle_version": {
      "type": "string"
    },
    "bundle_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "safe_state_id": {
      "type": "string",
      "minLength": 1
    },
    "authorized_tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tool_hashes": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "allowed_targets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "time_window": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "start",
            "end"
          ],
          "properties": {
            "start": {
              "type": "string",
              "format": "date-time"
            },
            "end": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "essential_tools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "coa": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_coa_id",
        "coas"
      ],
      "properties": {
        "default_coa_id": {
          "type": "string"
        },
        "fallback_sequence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "coas": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "coa_id",
              "steps"
            ],
            "properties": {
              "coa_id": {
                "type": "string"
              },
              "steps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "tool_id",
                    "params"
                  ],
                  "properties": {
                    "step_id": {
                      "type": "string"
                    },
                    "tool_id": {
                      "type": "string"
                    },
                    "params": {
                      "type": "object"
                    },
                    "description": {
                      "type": "string"
                    }
                  }
                }
              },
              "off_nominal_triggers": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "decision_tree": {
      "$ref": "https://example.org/schemas/decision_tree.schema.json"
    },
    "tripwire_predicates": {
      "type": "array",
      "items": {
        "$ref": "https://example.org/schemas/tripwire_predicate.schema.json"
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mandate": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mandate_id",
            "version",
            "anchor_hash",
            "trace_chain_hash"
          ],
          "properties": {
            "mandate_id": {
              "type": "string"
            },
            "version": {
              "type": "string"
            },
            "anchor_hash": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "trace_chain_hash": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "selected_coa": {
              "type": "string"
            },
            "fallback_sequence": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "artifact": {
              "type": "object"
            }
          }
        },
        "lattice_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "policy_id",
            "version"
          ],
          "properties": {
            "policy_id": {
              "type": "string"
            },
            "version": {
              "type": "string"
            },
            "policy_hash": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "policy": {
              "type": "object"
            }
          }
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "alg",
        "pubkey_id",
        "sig_b64"
      ],
      "properties": {
        "alg": {
          "type": "string"
        },
        "pubkey_id": {
          "type": "string"
        },
        "sig_b64": {
          "type": "string"
        }
      }
    }
  }
}
